<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Trang chủ - Đăng ký KLTN HCM·UTE</title>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#1a4fad;--blue-dark:#0f3480;--blue-light:#e8f0fe;
  --red:#c0392b;--green:#1a7a4a;--orange:#d97706;
  --gray-bg:#f0f2f7;--gray-border:#dde1ea;--gray-text:#5a6478;
  --white:#fff;--shadow:0 2px 12px rgba(20,50,120,.08);
}
body{font-family:'Be Vietnam Pro',sans-serif;background:var(--gray-bg);min-height:100vh;color:#1a2340}

/* ── TOPBAR ── */
.topbar{background:var(--blue-dark);color:#fff;padding:0 32px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.2)}
.topbar-left{display:flex;align-items:center;gap:14px}
.topbar-brand{font-size:17px;font-weight:800;letter-spacing:1.5px}
.topbar-divider{width:1px;height:28px;background:rgba(255,255,255,.25)}
.topbar-title{font-size:13px;font-weight:500;opacity:.85}
.topbar-right{display:flex;align-items:center;gap:12px}
.user-chip{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);padding:6px 14px;border-radius:20px;font-size:12.5px;display:flex;align-items:center;gap:6px}
.user-role{background:rgba(255,255,255,.2);padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;letter-spacing:.5px}
.btn-logout{background:transparent;border:1px solid rgba(255,255,255,.3);color:#fff;padding:7px 16px;border-radius:4px;font-family:inherit;font-size:13px;cursor:pointer;transition:.15s}
.btn-logout:hover{background:rgba(255,255,255,.1)}

/* ── HERO BANNER ── */
.hero{background:linear-gradient(135deg,var(--blue-dark) 0%,var(--blue) 100%);color:#fff;padding:36px 32px 32px;position:relative;overflow:hidden}
.hero::after{content:'';position:absolute;right:-60px;top:-60px;width:280px;height:280px;border-radius:50%;background:rgba(255,255,255,.05)}
.hero::before{content:'';position:absolute;right:80px;bottom:-40px;width:160px;height:160px;border-radius:50%;background:rgba(255,255,255,.04)}
.hero-content{position:relative;z-index:1;max-width:1100px;margin:0 auto}
.hero-greeting{font-size:13.5px;opacity:.8;margin-bottom:6px}
.hero-name{font-size:24px;font-weight:800;margin-bottom:4px}
.hero-sub{font-size:13.5px;opacity:.75}
.hero-stats{display:flex;gap:24px;margin-top:20px;flex-wrap:wrap}
.hero-stat{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.15);padding:12px 20px;border-radius:8px;text-align:center;min-width:110px}
.hero-stat-val{font-size:22px;font-weight:800}
.hero-stat-label{font-size:11.5px;opacity:.8;margin-top:2px}

/* ── MAIN LAYOUT ── */
.main{max-width:1100px;margin:0 auto;padding:28px 32px}

/* ── SECTION TITLE ── */
.sec-title{font-size:15px;font-weight:700;color:var(--blue-dark);margin-bottom:14px;display:flex;align-items:center;gap:8px;padding-bottom:8px;border-bottom:2px solid var(--blue-light)}
.sec-title::before{content:'';width:4px;height:18px;background:var(--blue);border-radius:2px;display:inline-block}

/* ── QUICK ACTIONS ── */
.actions-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:32px}
.action-card{background:var(--white);border-radius:8px;padding:20px;box-shadow:var(--shadow);border:1px solid var(--gray-border);cursor:pointer;transition:.2s;text-decoration:none;display:flex;flex-direction:column;align-items:flex-start;gap:10px;border-left:4px solid transparent}
.action-card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(26,79,173,.12);border-left-color:var(--blue)}
.action-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px}
.action-icon.blue{background:var(--blue-light)}
.action-icon.green{background:#d1fae5}
.action-icon.orange{background:#fef3c7}
.action-icon.red{background:#fee2e2}
.action-title{font-size:14px;font-weight:700;color:#1a2340}
.action-sub{font-size:12px;color:var(--gray-text);line-height:1.5}

/* ── STATUS CARD ── */
.status-section{margin-bottom:32px}
.status-card{background:var(--white);border-radius:8px;box-shadow:var(--shadow);border:1px solid var(--gray-border);overflow:hidden}
.status-header{padding:16px 20px;border-bottom:1px solid var(--gray-border);display:flex;align-items:center;justify-content:space-between}
.status-header-title{font-size:14px;font-weight:700;color:#1a2340}
.badge{display:inline-block;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600}
.badge.wait{background:#fef3c7;color:#92400e}
.badge.yes{background:#d1fae5;color:#065f46}
.badge.no{background:#fee2e2;color:#991b1b}
.badge.none{background:#f3f4f6;color:#6b7280}
.status-body{padding:20px}
.info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px}
.info-item label{font-size:11.5px;color:var(--gray-text);font-weight:600;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:4px}
.info-item p{font-size:14px;color:#1a2340;font-weight:500}
.no-data{text-align:center;padding:32px;color:var(--gray-text)}
.no-data-icon{font-size:40px;margin-bottom:10px}
.no-data p{font-size:14px}
.btn-register{margin-top:16px;padding:10px 24px;background:var(--blue);color:#fff;border:none;border-radius:6px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;transition:.15s}
.btn-register:hover{background:var(--blue-dark)}

/* ── GIẢNG VIÊN TABLE ── */
.gv-table-wrap{background:var(--white);border-radius:8px;box-shadow:var(--shadow);border:1px solid var(--gray-border);overflow:auto;margin-bottom:32px}
.gv-toolbar{padding:14px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--gray-border)}
.search-inp{padding:8px 14px;border:1.5px solid var(--gray-border);border-radius:6px;font-family:inherit;font-size:13.5px;outline:none;width:220px;transition:.2s}
.search-inp:focus{border-color:var(--blue)}
table{width:100%;border-collapse:collapse;min-width:500px}
thead tr{background:#f8f9fb}
th{padding:11px 16px;text-align:left;font-size:12px;font-weight:700;color:var(--gray-text);text-transform:uppercase;letter-spacing:.4px;border-bottom:1.5px solid var(--gray-border)}
td{padding:12px 16px;font-size:13.5px;border-bottom:1px solid #f0f0f0;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#f8f9fb}
.gv-avatar{width:34px;height:34px;border-radius:50%;background:var(--blue-light);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--blue);flex-shrink:0}
.gv-info{display:flex;align-items:center;gap:10px}

/* ── THÔNG BÁO ── */
.notice-section{margin-bottom:32px}
.notice-card{background:var(--white);border-radius:8px;box-shadow:var(--shadow);border:1px solid var(--gray-border);overflow:hidden}
.notice-item{padding:14px 20px;border-bottom:1px solid #f0f0f0;display:flex;gap:12px;align-items:flex-start}
.notice-item:last-child{border-bottom:none}
.notice-dot{width:8px;height:8px;border-radius:50%;background:var(--blue);flex-shrink:0;margin-top:6px}
.notice-dot.red{background:var(--red)}
.notice-dot.orange{background:var(--orange)}
.notice-content p{font-size:13.5px;color:#1a2340;font-weight:500}
.notice-content span{font-size:12px;color:var(--gray-text)}

/* ── OVERLAY ── */
.overlay{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;z-index:9999;background:rgba(6,95,70,.92)}
.overlay.show{display:flex}
.overlay.error{background:rgba(153,27,27,.92)}
.overlay-icon{font-size:64px;margin-bottom:16px}
.overlay-msg{font-size:22px;font-weight:700;color:#fff;text-align:center;padding:0 24px}
.overlay-sub{font-size:14px;color:rgba(255,255,255,.8);margin-top:8px}

/* ── MODAL ĐĂNG KÝ ── */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;z-index:500;min-height:100vh}
.modal-bg.show{display:flex}
.modal{background:#fff;border-radius:10px;padding:32px;width:100%;max-width:500px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.modal-title{font-size:18px;font-weight:800;color:var(--blue-dark);margin-bottom:4px}
.modal-sub{font-size:13px;color:var(--gray-text);margin-bottom:20px}
.field{margin-bottom:14px}
.field label{font-size:12.5px;font-weight:600;color:#374151;display:block;margin-bottom:5px}
.field input,.field select{width:100%;padding:11px 14px;border:1.5px solid var(--gray-border);border-radius:6px;font-family:inherit;font-size:13.5px;color:#111;outline:none;transition:.2s}
.field input:focus,.field select:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(26,79,173,.1)}
.field input[readonly]{background:#f9fafb;color:var(--gray-text)}
.modal-btns{display:flex;gap:10px;margin-top:20px}
.btn-cancel{flex:1;padding:11px;background:#fff;border:1.5px solid var(--gray-border);border-radius:6px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;color:var(--gray-text)}
.btn-submit{flex:2;padding:11px;background:var(--blue);color:#fff;border:none;border-radius:6px;font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;transition:.15s}
.btn-submit:hover{background:var(--blue-dark)}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── ROLE TAG ── */
.role-sv{color:var(--blue);background:var(--blue-light);padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700}
.role-gv{color:#065f46;background:#d1fae5;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700}

@media(max-width:600px){
  .main{padding:16px}
  .hero{padding:24px 16px}
  .topbar{padding:0 16px}
  .hero-stats{gap:12px}
}
</style>
</head>
<body>

<!-- Overlay -->
<div class="overlay" id="overlay">
  <div class="overlay-icon" id="ov-icon"></div>
  <div class="overlay-msg" id="ov-msg"></div>
  <div class="overlay-sub" id="ov-sub"></div>
</div>

<!-- Modal Đăng ký -->
<div class="modal-bg" id="modal-bg">
  <div class="modal">
    <div class="modal-title">📝 Đăng ký đề tài KLTN</div>
    <div class="modal-sub">Điền đầy đủ thông tin bên dưới</div>
    <div class="field"><label>Họ và tên *</label><input type="text" id="m-hoten" placeholder="Nguyễn Văn A"/></div>
    <div class="field"><label>MSSV *</label><input type="text" id="m-mssv" placeholder="23124153"/></div>
    <div class="field"><label>Gmail sinh viên</label><input type="text" id="m-gmail" readonly/></div>
    <div class="field"><label>Tên đề tài KLTN *</label><input type="text" id="m-detai" placeholder="Nhập tên đề tài của bạn"/></div>
    <div class="field"><label>Giảng viên hướng dẫn *</label>
      <select id="m-gvhd">
        <option value="">-- Chọn giảng viên --</option>
      </select>
    </div>
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closeModal()">Hủy</button>
      <button class="btn-submit" id="btn-submit" onclick="submitForm()">Gửi đăng ký</button>
    </div>
  </div>
</div>

<!-- Topbar -->
<div class="topbar">
  <div class="topbar-left">
    <div class="topbar-brand">HCM·UTE</div>
    <div class="topbar-divider"></div>
    <div class="topbar-title">Cổng Đăng ký Khóa Luận Tốt Nghiệp</div>
  </div>
  <div class="topbar-right">
    <div class="user-chip">
      👤 <span id="chip-email">...</span>
      <span class="user-role" id="chip-role">...</span>
    </div>
    <button class="btn-logout" onclick="logout()">Đăng xuất</button>
  </div>
</div>

<!-- Hero -->
<div class="hero">
  <div class="hero-content">
    <div class="hero-greeting">Xin chào,</div>
    <div class="hero-name" id="hero-name">...</div>
    <div class="hero-sub">Hệ thống đăng ký và quản lý đề tài Khóa Luận Tốt Nghiệp — HCM·UTE</div>
    <div class="hero-stats">
      <div class="hero-stat"><div class="hero-stat-val" id="stat-total">–</div><div class="hero-stat-label">Tổng đăng ký</div></div>
      <div class="hero-stat"><div class="hero-stat-val" id="stat-wait">–</div><div class="hero-stat-label">Chờ xác nhận</div></div>
      <div class="hero-stat"><div class="hero-stat-val" id="stat-yes">–</div><div class="hero-stat-label">Đã nhận</div></div>
      <div class="hero-stat"><div class="hero-stat-val" id="stat-no">–</div><div class="hero-stat-label">Từ chối</div></div>
    </div>
  </div>
</div>

<!-- Main -->
<div class="main">

  <!-- Quick Actions -->
  <div class="sec-title">Công cụ nhanh</div>
  <div class="actions-grid" id="actions-grid">
    <!-- Render by JS -->
  </div>

  <!-- Trạng thái đề tài (sinh viên) -->
  <div class="status-section" id="sv-status" style="display:none">
    <div class="sec-title">Thông tin đề tài của bạn</div>
    <div class="status-card" id="status-card">
      <div class="status-header">
        <div class="status-header-title">Đề tài đã đăng ký</div>
        <span class="badge none" id="status-badge">Chưa đăng ký</span>
      </div>
      <div class="status-body" id="status-body">
        <div class="no-data">
          <div class="no-data-icon">📋</div>
          <p>Bạn chưa đăng ký đề tài nào.</p>
          <button class="btn-register" onclick="openModal()">Đăng ký ngay</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Danh sách giảng viên -->
  <div id="gv-list-section" style="display:none">
    <div class="sec-title">Danh sách giảng viên hướng dẫn</div>
    <div class="gv-table-wrap">
      <div class="gv-toolbar">
        <span style="font-size:14px;font-weight:700;color:#1a3a7a">Giảng viên phụ trách</span>
        <input class="search-inp" id="gv-search" placeholder="Tìm giảng viên..." oninput="filterGV()"/>
      </div>
      <table>
        <thead><tr><th>STT</th><th>Họ và tên</th><th>MSSV/Mã GV</th><th>Gmail</th><th>Vai trò</th></tr></thead>
        <tbody id="gv-tbody"></tbody>
      </table>
    </div>
  </div>

  <!-- Thông báo -->
  <div class="notice-section">
    <div class="sec-title">Thông báo & Hướng dẫn</div>
    <div class="notice-card">
      <div class="notice-item">
        <div class="notice-dot red"></div>
        <div class="notice-content">
          <p>Hạn đăng ký đề tài KLTN: <strong>30/04/2025</strong></p>
          <span>Sinh viên cần hoàn tất đăng ký trước ngày trên</span>
        </div>
      </div>
      <div class="notice-item">
        <div class="notice-dot orange"></div>
        <div class="notice-content">
          <p>Mỗi sinh viên chỉ được đăng ký <strong>1 đề tài</strong></p>
          <span>Liên hệ giảng viên cố vấn nếu cần thay đổi đề tài</span>
        </div>
      </div>
      <div class="notice-item">
        <div class="notice-dot"></div>
        <div class="notice-content">
          <p>Giảng viên sẽ xác nhận trong vòng <strong>3–5 ngày làm việc</strong></p>
          <span>Kiểm tra trạng thái đề tài tại trang này</span>
        </div>
      </div>
      <div class="notice-item">
        <div class="notice-dot"></div>
        <div class="notice-content">
          <p>Mọi thắc mắc liên hệ: <strong>phongdaotao@hcmute.edu.vn</strong></p>
          <span>Giờ làm việc: Thứ 2 – Thứ 6, 8:00 – 17:00</span>
        </div>
      </div>
    </div>
  </div>

</div><!-- end main -->

<script>
const API = 'https://script.google.com/macros/s/AKfycbzVnS2plVyKHB1s8pD5pHCNKBKHeOoY6SG5Ys0qW4CDUyt7pNNOG_n_rfWZhVYGgOds/exec';

// Kiểm tra đăng nhập
const email = sessionStorage.getItem('ute_email');
const role  = sessionStorage.getItem('ute_role');
if(!email){ window.location.href='login.html'; }

// Hiển thị thông tin user
document.getElementById('chip-email').textContent = email;
document.getElementById('chip-role').textContent = role === 'sinhvien' ? 'SINH VIÊN' : role === 'giangvien' ? 'GIẢNG VIÊN' : 'ADMIN';
document.getElementById('hero-name').textContent = email;

// Quick Actions theo role
const svActions = [
  {icon:'📝',cls:'blue',title:'Đăng ký đề tài',sub:'Điền thông tin và gửi đề tài KLTN',onclick:'openModal()'},
  {icon:'📊',cls:'green',title:'Xem trạng thái',sub:'Kiểm tra tình trạng đề tài đã nộp',onclick:'scrollToStatus()'},
  {icon:'👨‍🏫',cls:'orange',title:'Danh sách giảng viên',sub:'Xem GV hướng dẫn có thể chọn',onclick:'scrollToGV()'},
  {icon:'📋',cls:'red',title:'Hướng dẫn đăng ký',sub:'Xem quy trình và yêu cầu KLTN',onclick:'showGuide()'},
];
const gvActions = [
  {icon:'📋',cls:'blue',title:'Danh sách đăng ký',sub:'Xem toàn bộ đề tài sinh viên đã nộp',onclick:"window.location.href='giangvien.html'"},
  {icon:'✅',cls:'green',title:'Xác nhận đề tài',sub:'Nhận hoặc từ chối lời mời hướng dẫn',onclick:"window.location.href='giangvien.html'"},
  {icon:'👨‍🎓',cls:'orange',title:'Danh sách sinh viên',sub:'Xem sinh viên thuộc diện đăng ký',onclick:'scrollToGV()'},
  {icon:'📊',cls:'red',title:'Thống kê',sub:'Xem thống kê đăng ký theo đợt',onclick:'scrollToHero()'},
];

function renderActions(){
  const actions = (role === 'sinhvien') ? svActions : gvActions;
  document.getElementById('actions-grid').innerHTML = actions.map(a=>`
    <div class="action-card" onclick="${a.onclick}">
      <div class="action-icon ${a.cls}">${a.icon}</div>
      <div>
        <div class="action-title">${a.title}</div>
        <div class="action-sub">${a.sub}</div>
      </div>
    </div>`).join('');
}

// Load data
async function loadData(){
  try {
    const res = await fetch(`${API}?action=getRegistrations`);
    const json = await res.json();
    const data = json.data || [];

    // Stats
    document.getElementById('stat-total').textContent = data.length;
    document.getElementById('stat-wait').textContent  = data.filter(r=>r['Xác nhận']==='Chờ xác nhận').length;
    document.getElementById('stat-yes').textContent   = data.filter(r=>r['Xác nhận']==='Đã nhận').length;
    document.getElementById('stat-no').textContent    = data.filter(r=>r['Xác nhận']==='Từ chối').length;

    // Sinh viên: xem đề tài của mình
    if(role === 'sinhvien'){
      document.getElementById('sv-status').style.display = 'block';
      const mine = data.find(r => (r['Gmail']||'').toLowerCase() === email.toLowerCase());
      if(mine){
        const status = mine['Xác nhận'] || 'Chờ xác nhận';
        const badgeClass = status==='Đã nhận'?'yes':status==='Từ chối'?'no':'wait';
        document.getElementById('status-badge').className = 'badge '+badgeClass;
        document.getElementById('status-badge').textContent = status;
        document.getElementById('status-body').innerHTML = `
          <div class="info-grid">
            <div class="info-item"><label>Họ và tên</label><p>${mine['Họ tên']||'–'}</p></div>
            <div class="info-item"><label>MSSV</label><p>${mine['MSSV']||'–'}</p></div>
            <div class="info-item"><label>Gmail</label><p>${mine['Gmail']||'–'}</p></div>
            <div class="info-item"><label>GVHD</label><p>${mine['GVHD']||'–'}</p></div>
            <div class="info-item" style="grid-column:1/-1"><label>Tên đề tài</label><p>${mine['Đề tài']||'–'}</p></div>
            <div class="info-item"><label>Thời gian nộp</label><p>${mine['Thời gian']||'–'}</p></div>
            <div class="info-item"><label>Trạng thái</label><p><span class="badge ${badgeClass}">${status}</span></p></div>
          </div>`;
      }
    }
  } catch(e){ console.log(e); }
}

// Load giảng viên
let gvData = [];
async function loadGV(){
  try {
    const res = await fetch(`${API}?action=getGiangVien`);
    const json = await res.json();
    gvData = json.data || [];
    renderGV(gvData);
    // Đổ vào select modal
    const sel = document.getElementById('m-gvhd');
    gvData.forEach(g=>{
      const opt = document.createElement('option');
      opt.value = g['Họ và Tên']||g['ho_ten']||'';
      opt.textContent = g['Họ và Tên']||g['ho_ten']||'';
      sel.appendChild(opt);
    });
  } catch(e){
    // Nếu chưa có API getGiangVien, dùng data mẫu
    gvData = [];
    renderGV(gvData);
  }
}

function renderGV(data){
  const tbody = document.getElementById('gv-tbody');
  if(!data.length){
    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:#9ca3af">Chưa có dữ liệu giảng viên</td></tr>';
    return;
  }
  tbody.innerHTML = data.map((g,i)=>{
    const name = g['Họ và Tên']||g['ho_ten']||'';
    const initials = name.split(' ').slice(-2).map(w=>w[0]).join('').toUpperCase();
    return `<tr>
      <td>${i+1}</td>
      <td><div class="gv-info"><div class="gv-avatar">${initials}</div><strong>${name}</strong></div></td>
      <td>${g['MSSV']||g['ma_gv']||'–'}</td>
      <td style="font-size:12.5px;color:#6b7280">${g['Gmail']||g['gmail']||'–'}</td>
      <td><span class="role-gv">Giảng viên</span></td>
    </tr>`;
  }).join('');
}

function filterGV(){
  const q = document.getElementById('gv-search').value.toLowerCase();
  if(!q){ renderGV(gvData); return; }
  renderGV(gvData.filter(g=>(g['Họ và Tên']||'').toLowerCase().includes(q)||(g['Gmail']||'').toLowerCase().includes(q)));
}

// Modal
function openModal(){
  document.getElementById('m-gmail').value = email;
  document.getElementById('modal-bg').className = 'modal-bg show';
}
function closeModal(){
  document.getElementById('modal-bg').className = 'modal-bg';
}

async function submitForm(){
  const hoTen = document.getElementById('m-hoten').value.trim();
  const mssv  = document.getElementById('m-mssv').value.trim();
  const deTai = document.getElementById('m-detai').value.trim();
  const gvhd  = document.getElementById('m-gvhd').value.trim();
  if(!hoTen||!mssv||!deTai||!gvhd){ alert('Vui lòng điền đầy đủ thông tin!'); return; }

  const btn = document.getElementById('btn-submit');
  btn.innerHTML = '<span class="spinner"></span> Đang gửi...';
  btn.disabled = true;

  try {
    await fetch(API,{method:'POST',body:JSON.stringify({action:'register',hoTen,mssv,gmail:email,deTai,gvhd})});
    closeModal();
    showOverlay('✅','Đăng ký thành công!','Thông tin của bạn đã được ghi nhận');
    setTimeout(()=>{ document.getElementById('overlay').className='overlay'; loadData(); },3000);
  } catch(e){
    showOverlay('⚠️','Lỗi kết nối. Vui lòng thử lại.','');
    setTimeout(()=>{ document.getElementById('overlay').className='overlay'; },3000);
  }
  btn.innerHTML = 'Gửi đăng ký';
  btn.disabled = false;
}

function showOverlay(icon,msg,sub){
  document.getElementById('ov-icon').textContent=icon;
  document.getElementById('ov-msg').textContent=msg;
  document.getElementById('ov-sub').textContent=sub||'';
  document.getElementById('overlay').className='overlay show';
}

function scrollToStatus(){ document.getElementById('sv-status').scrollIntoView({behavior:'smooth'}); }
function scrollToGV(){ document.getElementById('gv-list-section').scrollIntoView({behavior:'smooth'}); }
function scrollToHero(){ window.scrollTo({top:0,behavior:'smooth'}); }
function showGuide(){ alert('📋 Hướng dẫn đăng ký KLTN:\n\n1. Chọn "Đăng ký đề tài"\n2. Điền đầy đủ thông tin\n3. Chọn giảng viên hướng dẫn\n4. Chờ giảng viên xác nhận (3-5 ngày)\n5. Kiểm tra trạng thái tại trang này'); }
function logout(){ sessionStorage.clear(); window.location.href='login.html'; }

// Hiển thị section theo role
function initRole(){
  document.getElementById('sv-status').style.display = role==='sinhvien' ? 'block' : 'none';
  document.getElementById('gv-list-section').style.display = 'block';
}

// Init
renderActions();
initRole();
loadData();
loadGV();
</script>
